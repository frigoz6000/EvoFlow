## .gitignore for EvoFlow Solution

# Build outputs
bin/
obj/
dist/
build/

# Visual Studio
.vs/
*.user
*.suo

# .NET
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json

# NuGet
nuget.config

# Node / React
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment / secrets
appsettings.Development.json
*.env
.env.*

# OS
.DS_Store
Thumbs.db

# Rider / JetBrains
.idea/

# Paperclip memory
memory/
