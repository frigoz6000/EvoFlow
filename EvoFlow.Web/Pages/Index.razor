@page "/"
@using EvoFlow.Web.Services
@using EvoFlow.Web.Models
@inject EvoFlowApiService Api
@inject IJSRuntime JS

<PageTitle>EvoFlow - Sales Dashboard</PageTitle>

@if (loading)
{
    <div class="d-flex align-items-center gap-2 text-muted mt-3">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        <span>Loading dashboard...</span>
    </div>
}
else if (error != null)
{
    <div class="alert alert-danger mt-3">@error</div>
}
else
{
    <!-- Header -->
    <div class="d-flex align-items-start justify-content-between mb-4">
        <div>
            <h5 class="mb-1 fw-bold" style="color:var(--text-primary)">Sales Dashboard</h5>
            <p class="mb-0" style="font-size:0.8rem;color:var(--text-muted)">Fuel analytics overview across all sites</p>
        </div>
        <span style="font-size:0.75rem;color:var(--text-muted);margin-top:0.2rem">@tradingDays trading days of data</span>
    </div>

    <!-- Stat Cards Row 1 -->
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-card-header">
                    <span class="stat-card-label">Total Revenue</span>
                    <div class="stat-card-icon" style="background:var(--pink-light);color:var(--pink)">£</div>
                </div>
                <div class="stat-card-value">@FormatMoney(totalRevenue)</div>
                <div class="stat-card-sub">All pump transactions</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-card-header">
                    <span class="stat-card-label">Total Volume</span>
                    <div class="stat-card-icon" style="background:var(--purple-light);color:var(--purple)">
                        <span class="oi oi-grid-three-up" style="font-size:0.8rem"></span>
                    </div>
                </div>
                <div class="stat-card-value">@FormatLitres(totalVolume)</div>
                <div class="stat-card-sub">Fuel dispensed (litres)</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-card-header">
                    <span class="stat-card-label">Total Sites</span>
                    <div class="stat-card-icon" style="background:var(--blue-light);color:var(--blue)">
                        <span class="oi oi-map-marker" style="font-size:0.8rem"></span>
                    </div>
                </div>
                <div class="stat-card-value">@(sites?.Count.ToString("N0") ?? "—")</div>
                <div class="stat-card-sub">Registered locations</div>
            </div>
        </div>
    </div>

    <!-- Stat Cards Row 2 -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-card-header">
                    <span class="stat-card-label">Total Pumps</span>
                    <div class="stat-card-icon" style="background:var(--amber-light);color:var(--amber)">
                        <span class="oi oi-elevator" style="font-size:0.8rem"></span>
                    </div>
                </div>
                <div class="stat-card-value">@(pumps?.Count.ToString("N0") ?? "—")</div>
                <div class="stat-card-sub">@onlinePumps currently online</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-card-header">
                    <span class="stat-card-label">Avg Daily Revenue</span>
                    <div class="stat-card-icon" style="background:var(--pink-light);color:var(--pink)">
                        <span class="oi oi-pulse" style="font-size:0.8rem"></span>
                    </div>
                </div>
                <div class="stat-card-value">@FormatMoney(avgDailyRevenue)</div>
                <div class="stat-card-sub">Over @tradingDays trading days</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-card-header">
                    <span class="stat-card-label">Avg Revenue / Pump</span>
                    <div class="stat-card-icon" style="background:var(--green-light);color:var(--green)">
                        <span class="oi oi-graph" style="font-size:0.8rem"></span>
                    </div>
                </div>
                <div class="stat-card-value">@FormatMoney(avgRevPerPump)</div>
                <div class="stat-card-sub">Across all pump devices</div>
            </div>
        </div>
    </div>

    <!-- Charts Row 1 -->
    <div class="row g-3 mb-3">
        <!-- Fuel Sales Overview -->
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <span>Fuel Sales Overview</span>
                    <span style="font-size:0.7rem;color:var(--text-muted);font-weight:400">Revenue &amp; Volume by Day</span>
                </div>
                <div class="card-body">
                    <div class="chart-container" style="height:220px">
                        <canvas id="salesOverviewChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <!-- Pump Status -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header">Pump Status</div>
                <div class="card-body d-flex flex-column align-items-center justify-content-center">
                    <div class="donut-wrapper" style="width:160px;height:160px">
                        <canvas id="pumpStatusChart"></canvas>
                        <div class="donut-center">
                            <div class="donut-center-value">@(pumps?.Count.ToString("N0"))</div>
                            <div class="donut-center-label">Total</div>
                        </div>
                    </div>
                    <div class="donut-legend mt-2">
                        <div class="donut-legend-item">
                            <div class="donut-legend-dot" style="background:#22c55e"></div>
                            Online <strong>@onlinePumps</strong>
                        </div>
                        <div class="donut-legend-item">
                            <div class="donut-legend-dot" style="background:#e2e8f0;border:1px solid var(--border-color)"></div>
                            Offline <strong>@offlinePumps</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row 2 -->
    <div class="row g-3">
        <!-- Top Sites by Revenue -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <span>Top Sites by Revenue</span>
                    <span style="font-size:0.7rem;color:var(--text-muted);font-weight:400">Sort by highest</span>
                </div>
                <div class="card-body py-1">
                    @foreach (var (site, i) in topSites.Select((s, i) => (s, i)))
                    {
                        <div class="site-bar-row">
                            <span class="site-bar-rank">#@(i + 1)</span>
                            <span class="site-bar-name">@site.SiteName</span>
                            <div class="site-bar-track">
                                <div class="site-bar-fill" style="width:@(topSites.Count > 0 ? (int)(site.Revenue / topSites[0].Revenue * 100) : 0)%"></div>
                            </div>
                            <span class="site-bar-value">@FormatMoneyShort(site.Revenue)</span>
                        </div>
                    }
                </div>
            </div>
        </div>
        <!-- Daily Revenue Breakdown -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <span>Daily Revenue Breakdown</span>
                    <span style="font-size:0.7rem;color:var(--text-muted);font-weight:400">£ Revenue per trading day</span>
                </div>
                <div class="card-body">
                    <div class="chart-container" style="height:220px">
                        <canvas id="dailyRevenueChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    List<Site>? sites;
    List<PumpDevice>? pumps;
    List<PumpTotals>? pumpTotals;
    bool loading = true;
    string? error;

    decimal totalRevenue;
    decimal totalVolume;
    decimal avgDailyRevenue;
    decimal avgRevPerPump;
    int tradingDays;
    int onlinePumps;
    int offlinePumps;

    record SiteRevenue(string SiteId, string SiteName, decimal Revenue);
    List<SiteRevenue> topSites = new();

    List<string> dateLabels = new();
    List<double> revenueByDay = new();
    List<double> volumeByDay = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var sitesTask = Api.GetSitesAsync();
            var pumpsTask = Api.GetPumpDevicesAsync();
            var totalsTask = Api.GetPumpTotalsAsync();
            await Task.WhenAll(sitesTask, pumpsTask, totalsTask);
            sites = sitesTask.Result ?? new();
            pumps = pumpsTask.Result ?? new();
            pumpTotals = totalsTask.Result ?? new();

            onlinePumps = pumps.Count(p => p.Online);
            offlinePumps = pumps.Count(p => !p.Online);

            var dates = pumpTotals.Select(t => t.BusinessDate).Distinct().OrderBy(d => d).ToList();
            tradingDays = dates.Count;

            totalRevenue = pumpTotals.Sum(t => t.MoneyDiff);
            totalVolume = pumpTotals.Sum(t => t.VolumeDiff);
            avgDailyRevenue = tradingDays > 0 ? totalRevenue / tradingDays : 0;
            avgRevPerPump = pumps.Count > 0 ? totalRevenue / pumps.Count : 0;

            // Chart data by date
            dateLabels = dates.Select(d => d.Length >= 7 ? d.Substring(5) : d).ToList();
            revenueByDay = dates.Select(d => (double)pumpTotals.Where(t => t.BusinessDate == d).Sum(t => t.MoneyDiff)).ToList();
            volumeByDay = dates.Select(d => (double)pumpTotals.Where(t => t.BusinessDate == d).Sum(t => t.VolumeDiff)).ToList();

            // Top sites by revenue (join pump totals -> pump devices -> sites)
            var pumpSiteMap = pumps.ToDictionary(p => p.PumpDeviceId, p => p.SiteId);
            var siteMap = sites.ToDictionary(s => s.SiteId, s => s.SiteName);
            var revenuePerSite = pumpTotals
                .Where(t => pumpSiteMap.ContainsKey(t.PumpDeviceId))
                .GroupBy(t => pumpSiteMap[t.PumpDeviceId])
                .Select(g => new SiteRevenue(g.Key, siteMap.GetValueOrDefault(g.Key, g.Key), g.Sum(t => t.MoneyDiff)))
                .OrderByDescending(s => s.Revenue)
                .Take(6)
                .ToList();
            topSites = revenuePerSite;
        }
        catch (Exception ex)
        {
            error = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!loading && error == null && (firstRender || chartsRendered == false))
        {
            chartsRendered = true;
            await JS.InvokeVoidAsync("evoflow.renderAreaChart",
                "salesOverviewChart",
                dateLabels,
                "Vol (L)", volumeByDay,
                "£ Revenue", revenueByDay);

            await JS.InvokeVoidAsync("evoflow.renderDoughnutChart",
                "pumpStatusChart",
                onlinePumps, offlinePumps);

            await JS.InvokeVoidAsync("evoflow.renderBarChart",
                "dailyRevenueChart",
                dateLabels, revenueByDay);
        }
    }

    private bool chartsRendered = false;

    private string FormatMoney(decimal value)
    {
        if (value >= 1_000_000) return $"£{value / 1_000_000:F2}M";
        if (value >= 1_000) return $"£{value / 1_000:F1}K";
        return $"£{value:N0}";
    }

    private string FormatMoneyShort(decimal value)
    {
        if (value >= 1_000_000) return $"£{value / 1_000_000:F1}M";
        if (value >= 1_000) return $"£{value / 1_000:F1}K";
        return $"£{value:N0}";
    }

    private string FormatLitres(decimal value)
    {
        if (value >= 1_000_000) return $"{value / 1_000_000:F1}M L";
        if (value >= 1_000) return $"{value / 1_000:F1}K L";
        return $"{value:N0} L";
    }
}
