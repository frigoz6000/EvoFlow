@page "/pumps"
@using EvoFlow.Web.Services
@using EvoFlow.Web.Models
@inject EvoFlowApiService Api

<PageTitle>Pump Devices</PageTitle>

<h1>Pump Devices</h1>

@if (loading)
{
    <p><em>Loading pump devices...</em></p>
}
else if (error != null)
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Site</th>
                <th>Device</th>
                <th>Status</th>
                <th>Offline Count</th>
                <th>Protocol</th>
                <th>Last Seen (UTC)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pump in pumps ?? [])
            {
                <tr>
                    <td>@pump.PumpDeviceId</td>
                    <td>@pump.SiteId</td>
                    <td>@pump.DeviceId</td>
                    <td>
                        @if (pump.Online)
                        {
                            <span class="badge bg-success">Online</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Offline</span>
                        }
                    </td>
                    <td>@pump.OfflineCount</td>
                    <td>@pump.Protocol</td>
                    <td>@pump.LastSeenUtc.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    List<PumpDevice>? pumps;
    bool loading = true;
    string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            pumps = await Api.GetPumpDevicesAsync();
        }
        catch (Exception ex)
        {
            error = $"Failed to load pump devices: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }
}
