@code {
    [Parameter] public string Href { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public bool Collapsed { get; set; }
    [Parameter] public bool Exact { get; set; }
}

<div class="nav-item-wrapper">
    <NavLink class="nav-link-item" href="@Href" Match="@(Exact ? NavLinkMatch.All : NavLinkMatch.Prefix)" title="@(Collapsed ? Label : null)">
        <span class="oi @Icon nav-item-icon" aria-hidden="true"></span>
        @if (!Collapsed)
        {
            <span class="nav-item-label">@Label</span>
        }
    </NavLink>
</div>
