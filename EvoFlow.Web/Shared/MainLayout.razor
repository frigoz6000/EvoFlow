@inherits LayoutComponentBase
@inject IJSRuntime JS

<PageTitle>EvoFlow</PageTitle>

<div class="page @(sidebarCollapsed ? "sidebar-collapsed" : "")">
    <div class="sidebar">
        <NavMenu IsSidebarCollapsed="sidebarCollapsed" OnToggleCollapse="ToggleSidebar" />
    </div>

    @if (!sidebarCollapsed)
    {
        <div class="sidebar-overlay" @onclick="ToggleSidebar"></div>
    }

    <main>
        <div class="top-row">
            <div class="search-wrapper">
                <span class="oi oi-magnifying-glass search-icon"></span>
                <input type="text" class="search-input" placeholder="Search site ID or name..." />
            </div>
            <div class="top-row-actions">
                <button class="btn-icon" title="Toggle dark mode" @onclick="ToggleDarkMode">
                    @if (darkMode)
                    {
                        <span class="oi oi-sun" aria-hidden="true"></span>
                    }
                    else
                    {
                        <span class="oi oi-moon" aria-hidden="true"></span>
                    }
                </button>
                <div class="user-avatar" title="User">U</div>
            </div>
        </div>

        <article class="content px-4 py-3">
            @Body
        </article>
    </main>
</div>

@code {
    private bool sidebarCollapsed = false;
    private bool darkMode = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            darkMode = await JS.InvokeAsync<bool>("evoflow.getDarkMode");
            await JS.InvokeVoidAsync("evoflow.applyDarkMode", darkMode);

            var width = await JS.InvokeAsync<int>("evoflow.getWindowWidth");
            if (width < 768)
                sidebarCollapsed = true;

            StateHasChanged();
        }
    }

    private void ToggleSidebar()
    {
        sidebarCollapsed = !sidebarCollapsed;
    }

    private async Task ToggleDarkMode()
    {
        darkMode = !darkMode;
        await JS.InvokeVoidAsync("evoflow.applyDarkMode", darkMode);
        await JS.InvokeVoidAsync("evoflow.saveDarkMode", darkMode);
    }
}
