@code {
    [Parameter] public bool IsSidebarCollapsed { get; set; }
    [Parameter] public EventCallback OnToggleCollapse { get; set; }
}

<!-- Hamburger button at top -->
<div class="nav-hamburger">
    <button class="nav-hamburger-btn" @onclick="OnToggleCollapse" title="@(IsSidebarCollapsed ? "Expand menu" : "Collapse menu")">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
    </button>
    @if (!IsSidebarCollapsed)
    {
        <span class="nav-logo-text">EvoFlow</span>
    }
</div>

<!-- Navigation -->
<div class="nav-body">
    @if (!IsSidebarCollapsed)
    {
        <div class="nav-section-label">Main</div>
    }
    <NavItem Href="" Icon="oi-home" Label="Home" Collapsed="IsSidebarCollapsed" Exact="true" />
    <NavItem Href="alerts" Icon="oi-bell" Label="Alerts" Collapsed="IsSidebarCollapsed" />

    @if (!IsSidebarCollapsed)
    {
        <div class="nav-section-label">Monitoring</div>
    }
    else
    {
        <div class="nav-section-divider"></div>
    }
    <NavItem Href="fuelrecords" Icon="oi-list-rich" Label="Fuel Records" Collapsed="IsSidebarCollapsed" />
    <NavItem Href="pumpmonitor" Icon="oi-pulse" Label="Pump Monitor" Collapsed="IsSidebarCollapsed" />

    @if (!IsSidebarCollapsed)
    {
        <div class="nav-section-label">Sites</div>
    }
    else
    {
        <div class="nav-section-divider"></div>
    }
    <NavItem Href="allsites" Icon="oi-map-marker" Label="All Sites" Collapsed="IsSidebarCollapsed" />
</div>
